#! /bin/sh

# Main update script - expects a data directory as the only argument.
# Period 19 (current WP) is baked in. The ner flag is omitted here (routine
# update); VTT text needs no aeneas align. Run --extract-entities separately once
# the experimental VTT text join is validated. See manifest.yaml.

OUTPUT=${1?Missing output directory parameter (data base directory)}

CALLDIR="$(dirname "$(readlink "$0" 2>/dev/null || echo "$0")")"

python3 "${CALLDIR}/workflow.py" --period=19 \
    --retry-count=20 \
    --download-original --merge-speeches \
    --link-entities \
    "${OUTPUT}"
