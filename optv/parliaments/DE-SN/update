#! /bin/sh

# Main update script - expects a data directory as the only argument.
# Period 8 (current WP) is baked in. the align/ner flags are
# omitted here (routine update); run them separately once the experimental
# PDF→TEI text join is validated. See manifest.yaml.

OUTPUT=${1?Missing output directory parameter (data base directory)}

CALLDIR="$(dirname "$(readlink "$0" 2>/dev/null || echo "$0")")"

python3 "${CALLDIR}/workflow.py" --period=8 \
    --retry-count=20 \
    --download-original --merge-speeches \
    --link-entities \
    "${OUTPUT}"
